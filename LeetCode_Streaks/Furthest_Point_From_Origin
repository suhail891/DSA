class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int l=0;
        int r=0;
        int n=moves.length();
        for(int i=0; i < n; i++){
            if(moves.charAt(i)=='L'){
                l++;
            }else if(moves.charAt(i)=='R'){
                r++;
            }
        }
        int underScore=n-l-r;
        if(l>=r){
            return l+underScore-r;
        }
        return r+underScore-l;
    }
}
