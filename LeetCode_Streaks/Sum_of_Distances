class Solution {
    public long[] distance(int[] nums) {
        //brute force code 
        int n=nums.length;
        long[] ans=new long[n];
        for(int i=0;i<n;i++){
            long sum=0;
            for(int j=0;j<n;j++){
                if(nums[i]==nums[j] && i!=j){
                    sum=sum+Math.abs(i-j);
                }
            }
            ans[i]=sum;
        }
        return ans;
    }
}
