class Solution {
   private boolean dfs(char[][] grid, int row, int col,int m, int n,int prevRow,int prevCol, boolean[][] visit){
        visit[row][col]=true;

        int[] a={-1,0,0,1};
        int[] b={0,1,-1,0};
        for(int i=0;i<4;i++){
            int newRow=row+a[i];
            int newCol=col+b[i];
            if(newRow>=0 && newRow<m && newCol>=0 && newCol<n  && grid[newRow][newCol]==grid[row][col]){
                // parent condition
                if(prevRow==newRow && prevCol==newCol) {
                    continue;
                }

                // if not parent then
                if(visit[newRow][newCol]) {
                    return true;
                }
                // now check recursively 
                
                if (dfs(grid, newRow, newCol, m, n, row, col, visit)) {
                    return true;
                }
            }
        }
        return false;
    }
    public boolean containsCycle(char[][] grid) {
        int m=grid.length;
        int n=grid[0].length;

        boolean[][] visit=new boolean[m][n];
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(!visit[i][j]){
                    if(dfs(grid,i,j,m,n,-1,-1,visit)) return true;
                }
            }
        }
        return false;
    }
    
}
