FindDuplicate {
    public int findDuplicate(int[] nums) {
        //solution using tortoise and hare Algorithm

        int slow=nums[0];
        int fast=nums[0];
        do{
            slow=nums[slow];
            fast=nums[nums[fast]];
        }while(slow!=fast);
        //cylce is detect
        //now reintalize the fast
        fast=nums[0];
        while(slow!=fast){
            slow=nums[slow];
            fast=nums[fast];
        }
        return slow;
    }
}
